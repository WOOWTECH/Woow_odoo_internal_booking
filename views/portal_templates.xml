<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================ -->
    <!-- PORTAL HOME - Add Booking Counter -->
    <!-- ============================================================ -->

    <template id="portal_my_home_booking" name="Show Booking Count" inherit_id="portal.portal_my_home" priority="30">
        <!-- Add booking cards inside the existing portal_common_category -->
        <xpath expr="//div[@id='portal_common_category']" position="inside">
            <div class="o_portal_index_card col-md-6 order-3">
                <a href="/my/bookings" title="My Bookings" class="d-flex gap-2 gap-md-3 py-3 pe-2 px-md-3 h-100 rounded text-decoration-none bg-100">
                    <div class="o_portal_icon d-block align-self-start">
                        <i class="fa fa-calendar fa-2x text-muted"/>
                    </div>
                    <div>
                        <div class="mt-0 mb-1 fs-5 fw-normal lh-1">
                            <span>My Bookings</span>
                        </div>
                        <div class="opacity-75">View and manage your resource reservations</div>
                    </div>
                </a>
            </div>
            <div class="o_portal_index_card col-md-6 order-4">
                <a href="/my/booking/resources" title="Book Resources" class="d-flex gap-2 gap-md-3 py-3 pe-2 px-md-3 h-100 rounded text-decoration-none bg-100">
                    <div class="o_portal_icon d-block align-self-start">
                        <i class="fa fa-building-o fa-2x text-muted"/>
                    </div>
                    <div>
                        <div class="mt-0 mb-1 fs-5 fw-normal lh-1">
                            <span>Book Resources</span>
                        </div>
                        <div class="opacity-75">Browse and book available resources</div>
                    </div>
                </a>
            </div>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!-- RESOURCE LIST PAGE -->
    <!-- ============================================================ -->

    <template id="portal_my_resources" name="My Booking Resources">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <h3 class="mb-4">Available Resources</h3>

            <t t-if="not resources">
                <div class="alert alert-info" role="alert">
                    <i class="fa fa-info-circle"/> No resources are available for booking at this time.
                </div>
            </t>

            <t t-if="resources">
                <div class="row">
                    <t t-foreach="resources" t-as="resource">
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 booking-resource-card">
                                <t t-if="resource.image">
                                    <img t-attf-src="/web/image/booking.resource.type/#{resource.id}/image"
                                         class="card-img-top"
                                         style="height: 180px; object-fit: cover;"
                                         t-att-alt="resource.name"/>
                                </t>
                                <t t-else="">
                                    <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center"
                                         style="height: 180px;">
                                        <i class="fa fa-building-o fa-4x text-white"/>
                                    </div>
                                </t>
                                <div class="card-body">
                                    <h5 class="card-title">
                                        <t t-esc="resource.name"/>
                                    </h5>
                                    <p class="card-text text-muted">
                                        <t t-if="resource.location">
                                            <i class="fa fa-map-marker"/> <t t-esc="resource.location"/><br/>
                                        </t>
                                        <t t-if="resource.capacity">
                                            <i class="fa fa-users"/> Capacity: <t t-esc="resource.capacity"/>
                                        </t>
                                    </p>
                                </div>
                                <div class="card-footer bg-transparent">
                                    <a t-attf-href="/my/booking/resources/#{resource.id}"
                                       class="btn btn-primary btn-block">
                                        <i class="fa fa-calendar-plus-o"/> Book Now
                                    </a>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- RESOURCE DETAIL PAGE -->
    <!-- ============================================================ -->

    <template id="portal_resource_detail" name="Resource Detail">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <h3 class="mb-4"><t t-esc="resource.name"/></h3>

            <div class="row">
                <!-- Resource Info: show on top at lg+, below slots on mobile via order -->
                <div class="col-lg-4 mb-4 order-2 order-lg-1">
                    <div class="card ws-card-accent">
                        <t t-if="resource.image">
                            <img t-attf-src="/web/image/booking.resource.type/#{resource.id}/image"
                                 class="card-img-top d-none d-lg-block"
                                 t-att-alt="resource.name"/>
                        </t>
                        <div class="card-body">
                            <h5 class="card-title d-none d-lg-block"><t t-esc="resource.name"/></h5>

                            <dl class="row mb-0">
                                <t t-if="resource.location">
                                    <dt class="col-4 col-lg-5">Location</dt>
                                    <dd class="col-8 col-lg-7"><t t-esc="resource.location"/></dd>
                                </t>
                                <t t-if="resource.capacity">
                                    <dt class="col-4 col-lg-5">Capacity</dt>
                                    <dd class="col-8 col-lg-7"><t t-esc="resource.capacity"/> people</dd>
                                </t>
                                <dt class="col-4 col-lg-5">Duration</dt>
                                <dd class="col-8 col-lg-7"><t t-esc="resource.slot_duration"/> hour(s)</dd>
                            </dl>

                            <t t-if="resource.description">
                                <hr/>
                                <div t-raw="resource.description"/>
                            </t>
                        </div>
                    </div>

                    <div class="mt-3">
                        <a href="/my/booking/resources" class="btn btn-secondary btn-block">
                            <i class="fa fa-arrow-left"/> Back to Resources
                        </a>
                    </div>
                </div>

                <!-- Available Slots: show first on mobile via order -->
                <div class="col-lg-8 order-1 order-lg-2">
                    <div class="card">
                        <div class="card-header ws-slots-header">
                            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2">
                                <span><i class="fa fa-calendar"/> Available Time Slots</span>
                                <div class="d-flex align-items-center">
                                    <t t-if="show_prev">
                                        <a t-attf-href="/my/booking/resources/#{resource.id}?date=#{prev_week}"
                                           class="btn btn-sm ws-nav-btn">
                                            <i class="fa fa-chevron-left"/>
                                        </a>
                                    </t>
                                    <t t-else="">
                                        <span class="btn btn-sm ws-nav-btn disabled">
                                            <i class="fa fa-chevron-left"/>
                                        </span>
                                    </t>
                                    <span class="mx-2 text-nowrap ws-date-range">
                                        <t t-esc="date_from_str"/> - <t t-esc="date_to_str"/>
                                    </span>
                                    <t t-if="show_next">
                                        <a t-attf-href="/my/booking/resources/#{resource.id}?date=#{next_week}"
                                           class="btn btn-sm ws-nav-btn">
                                            <i class="fa fa-chevron-right"/>
                                        </a>
                                    </t>
                                    <t t-else="">
                                        <span class="btn btn-sm ws-nav-btn disabled">
                                            <i class="fa fa-chevron-right"/>
                                        </span>
                                    </t>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <t t-if="not slots">
                                <div class="alert alert-info">
                                    No available time slots for this period.
                                </div>
                            </t>

                            <t t-foreach="slots_by_date.items()" t-as="date_slots">
                                <h6 class="mt-3 mb-2 ws-date-heading">
                                    <t t-esc="date_slots[0]"/>
                                </h6>
                                <div class="row">
                                    <t t-foreach="date_slots[1]" t-as="slot">
                                        <div class="col-6 col-md-4 col-lg-3 mb-2">
                                            <t t-if="slot['is_available']">
                                                <a t-attf-href="/my/bookings/confirm?resource_id=#{resource.id}&amp;start_datetime=#{slot['start'].strftime('%Y-%m-%d %H:%M:%S')}&amp;end_datetime=#{slot['end'].strftime('%Y-%m-%d %H:%M:%S')}"
                                                   class="btn btn-outline-success btn-sm btn-block slot-btn">
                                                    <t t-esc="slot['start_str'].split(' ')[1]"/> - <t t-esc="slot['end_str']"/>
                                                </a>
                                            </t>
                                            <t t-elif="slot['is_mine']">
                                                <a t-attf-href="/my/bookings/#{slot['reservation_id']}"
                                                   class="btn btn-info btn-sm btn-block slot-btn">
                                                    <t t-esc="slot['start_str'].split(' ')[1]"/> - <t t-esc="slot['end_str']"/>
                                                    <br/><small>Your booking</small>
                                                </a>
                                            </t>
                                            <t t-else="">
                                                <button class="btn btn-secondary btn-sm btn-block slot-btn" disabled="disabled">
                                                    <t t-esc="slot['start_str'].split(' ')[1]"/> - <t t-esc="slot['end_str']"/>
                                                    <br/><small>Booked</small>
                                                </button>
                                            </t>
                                        </div>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- MY BOOKINGS LIST -->
    <!-- ============================================================ -->

    <template id="portal_my_bookings" name="My Bookings">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <h3 class="mb-3">My Bookings</h3>

            <!-- Actions Bar: stack vertically on mobile, horizontal on sm+ -->
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2 mb-3">
                <a href="/my/booking/resources" class="btn btn-primary">
                    <i class="fa fa-plus"/> New Booking
                </a>
                <div class="d-flex gap-2">
                    <!-- Filter Dropdown -->
                    <div class="dropdown">
                        <button class="btn btn-secondary dropdown-toggle btn-sm" type="button" data-bs-toggle="dropdown">
                            <i class="fa fa-filter"/> <t t-esc="filter_options[filterby]['label']"/>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <t t-foreach="filter_options.items()" t-as="option">
                                <li>
                                    <a class="dropdown-item"
                                       t-att-class="'active' if filterby == option[0] else ''"
                                       t-attf-href="/my/bookings?filterby=#{option[0]}&amp;sortby=#{sortby}">
                                        <t t-esc="option[1]['label']"/>
                                    </a>
                                </li>
                            </t>
                        </ul>
                    </div>

                    <!-- Sort Dropdown -->
                    <div class="dropdown">
                        <button class="btn btn-secondary dropdown-toggle btn-sm" type="button" data-bs-toggle="dropdown">
                            <i class="fa fa-sort"/> <t t-esc="sort_options[sortby]['label']"/>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <t t-foreach="sort_options.items()" t-as="option">
                                <li>
                                    <a class="dropdown-item"
                                       t-att-class="'active' if sortby == option[0] else ''"
                                       t-attf-href="/my/bookings?sortby=#{option[0]}&amp;filterby=#{filterby}">
                                        <t t-esc="option[1]['label']"/>
                                    </a>
                                </li>
                            </t>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Bookings: card list on mobile, table on md+ -->
            <t t-if="not reservations">
                <div class="alert alert-info" role="alert">
                    <i class="fa fa-info-circle"/> You don't have any bookings yet.
                    <a href="/my/booking/resources">Browse available resources</a> to make a booking.
                </div>
            </t>

            <t t-if="reservations">
                <!-- Mobile card layout (visible below md) -->
                <div class="d-md-none">
                    <t t-foreach="reservations" t-as="res">
                        <a t-attf-href="/my/bookings/#{res.id}" class="text-decoration-none">
                            <div t-att-class="'ws-booking-card mb-2' + (' ws-booking-card-cancelled' if res.state == 'cancelled' else ' ws-booking-card-confirmed')">
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1 me-2">
                                            <div class="ws-resource-name">
                                                <t t-esc="res.resource_type_id.name"/>
                                            </div>
                                            <small class="text-muted">
                                                <i class="fa fa-clock-o"/>
                                                <t t-esc="res.start_datetime" t-options="{'widget': 'datetime', 'format': 'MM/dd HH:mm'}"/>
                                                <span class="mx-1">·</span>
                                                <t t-esc="'%.1f' % res.duration"/>h
                                            </small>
                                            <t t-if="res.resource_location">
                                                <br/>
                                                <small class="text-muted">
                                                    <i class="fa fa-map-marker"/> <t t-esc="res.resource_location"/>
                                                </small>
                                            </t>
                                        </div>
                                        <div class="text-end">
                                            <t t-if="res.state == 'confirmed'">
                                                <span class="badge bg-success">Confirmed</span>
                                            </t>
                                            <t t-if="res.state == 'cancelled'">
                                                <span class="badge bg-danger">Cancelled</span>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </t>
                </div>

                <!-- Desktop table layout (visible md+) -->
                <div class="d-none d-md-block table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Resource</th>
                                <th>Date &amp; Time</th>
                                <th>Duration</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="reservations" t-as="res">
                                <tr t-att-class="'text-muted' if res.state == 'cancelled' else ''">
                                    <td>
                                        <a t-attf-href="/my/bookings/#{res.id}">
                                            <t t-esc="res.resource_type_id.name"/>
                                        </a>
                                        <t t-if="res.resource_location">
                                            <br/>
                                            <small class="text-muted">
                                                <i class="fa fa-map-marker"/> <t t-esc="res.resource_location"/>
                                            </small>
                                        </t>
                                    </td>
                                    <td>
                                        <t t-esc="res.start_datetime" t-options="{'widget': 'datetime', 'format': 'MMM dd, yyyy HH:mm'}"/>
                                    </td>
                                    <td>
                                        <t t-esc="'%.1f' % res.duration"/> hour(s)
                                    </td>
                                    <td>
                                        <t t-if="res.state == 'confirmed'">
                                            <span class="badge bg-success">Confirmed</span>
                                        </t>
                                        <t t-if="res.state == 'cancelled'">
                                            <span class="badge bg-danger">Cancelled</span>
                                        </t>
                                    </td>
                                    <td class="text-end">
                                        <a t-attf-href="/my/bookings/#{res.id}" class="btn btn-sm btn-outline-primary">
                                            <i class="fa fa-eye"/> View
                                        </a>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>

                <!-- Pager -->
                <div class="d-flex justify-content-center mt-3">
                    <t t-call="portal.pager"/>
                </div>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- BOOKING DETAIL PAGE -->
    <!-- ============================================================ -->

    <template id="portal_booking_detail" name="Booking Detail">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <h3 class="mb-4">Booking Details</h3>

            <!-- Success/Error Messages -->
            <t t-if="success == 'created'">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fa fa-check-circle"/> Your booking has been confirmed!
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"/>
                </div>
            </t>
            <t t-if="success == 'cancelled'">
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <i class="fa fa-times-circle"/> Your booking has been cancelled.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"/>
                </div>
            </t>
            <t t-if="error">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fa fa-exclamation-circle"/> <t t-esc="error"/>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"/>
                </div>
            </t>

            <div class="row">
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-header ws-card-header-accent d-flex justify-content-between align-items-center">
                            <span>
                                <i class="fa fa-calendar-check-o"/> Booking #<t t-esc="reservation.id"/>
                            </span>
                            <t t-if="reservation.state == 'confirmed'">
                                <span class="badge bg-success">Confirmed</span>
                            </t>
                            <t t-if="reservation.state == 'cancelled'">
                                <span class="badge bg-danger">Cancelled</span>
                            </t>
                        </div>
                        <div class="card-body">
                            <!-- Subject or Resource Name as title -->
                            <h4>
                                <t t-if="reservation.subject" t-esc="reservation.subject"/>
                                <t t-else="" t-esc="reservation.resource_type_id.name"/>
                            </h4>

                            <!-- Resource Info -->
                            <dl class="row">
                                <dt class="col-5 col-sm-4">Resource</dt>
                                <dd class="col-7 col-sm-8"><t t-esc="reservation.resource_type_id.name"/></dd>

                                <t t-if="reservation.resource_location">
                                    <dt class="col-5 col-sm-4">Location</dt>
                                    <dd class="col-7 col-sm-8"><t t-esc="reservation.resource_location"/></dd>
                                </t>
                            </dl>

                            <hr/>

                            <!-- Time -->
                            <dl class="row">
                                <dt class="col-5 col-sm-4">Start</dt>
                                <dd class="col-7 col-sm-8">
                                    <t t-esc="reservation.start_datetime" t-options="{'widget': 'datetime', 'format': 'EEEE, MMMM d, yyyy HH:mm'}"/>
                                </dd>

                                <dt class="col-5 col-sm-4">End</dt>
                                <dd class="col-7 col-sm-8">
                                    <t t-esc="reservation.end_datetime" t-options="{'widget': 'datetime', 'format': 'EEEE, MMMM d, yyyy HH:mm'}"/>
                                </dd>

                                <dt class="col-5 col-sm-4">Duration</dt>
                                <dd class="col-7 col-sm-8"><t t-esc="'%.1f' % reservation.duration"/> hour(s)</dd>
                            </dl>

                            <hr/>

                            <!-- People -->
                            <dl class="row">
                                <t t-if="reservation.organizer_id">
                                    <dt class="col-5 col-sm-4">Organizer</dt>
                                    <dd class="col-7 col-sm-8"><t t-esc="reservation.organizer_id.name"/></dd>
                                </t>

                                <dt class="col-5 col-sm-4">Booked By</dt>
                                <dd class="col-7 col-sm-8"><t t-esc="reservation.partner_id.name"/></dd>

                                <t t-if="reservation.attendee_ids">
                                    <dt class="col-5 col-sm-4">Attendees</dt>
                                    <dd class="col-7 col-sm-8">
                                        <t t-foreach="reservation.attendee_ids" t-as="att">
                                            <span class="badge bg-secondary me-1"><t t-esc="att.name"/></span>
                                        </t>
                                    </dd>
                                </t>
                            </dl>

                            <!-- Discussion Channel -->
                            <t t-if="reservation.channel_id">
                                <hr/>
                                <dl class="row">
                                    <dt class="col-5 col-sm-4">Discussion</dt>
                                    <dd class="col-7 col-sm-8">
                                        <a t-attf-href="/my/bookings/#{reservation.id}/discuss">
                                            <i class="fa fa-comments"/> <t t-esc="reservation.channel_id.name"/>
                                        </a>
                                    </dd>
                                </dl>
                            </t>

                            <!-- Description -->
                            <t t-if="reservation.description">
                                <hr/>
                                <h6 class="text-muted">Description</h6>
                                <div t-raw="reservation.description"/>
                            </t>

                            <!-- Legacy notes -->
                            <t t-if="reservation.note">
                                <hr/>
                                <h6 class="text-muted">Notes</h6>
                                <p><t t-esc="reservation.note"/></p>
                            </t>
                        </div>
                        <div class="card-footer">
                            <div class="d-flex flex-column-reverse flex-sm-row justify-content-between gap-2">
                                <a href="/my/bookings" class="btn btn-secondary">
                                    <i class="fa fa-arrow-left"/> Back
                                </a>
                                <t t-if="reservation.state == 'confirmed'">
                                    <form t-attf-action="/my/bookings/#{reservation.id}/cancel" method="post" class="d-inline">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <button type="submit" class="btn btn-danger w-100 w-sm-auto"
                                                onclick="return confirm('Are you sure you want to cancel this booking?');">
                                            <i class="fa fa-times"/> Cancel Booking
                                        </button>
                                    </form>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Resource Info Sidebar -->
                <div class="col-lg-4 mt-4 mt-lg-0">
                    <div class="card ws-card-accent">
                        <div class="card-header">
                            <i class="fa fa-info-circle"/> Resource Info
                        </div>
                        <div class="card-body">
                            <t t-if="reservation.resource_type_id.image">
                                <img t-attf-src="/web/image/booking.resource.type/#{reservation.resource_type_id.id}/image"
                                     class="img-fluid mb-3"
                                     t-att-alt="reservation.resource_type_id.name"/>
                            </t>
                            <h6><t t-esc="reservation.resource_type_id.name"/></h6>
                            <t t-if="reservation.resource_type_id.description">
                                <div t-raw="reservation.resource_type_id.description"/>
                            </t>
                        </div>
                        <div class="card-footer">
                            <a t-attf-href="/my/booking/resources/#{reservation.resource_type_id.id}"
                               class="btn btn-outline-primary btn-sm btn-block">
                                <i class="fa fa-calendar"/> Book Again
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- NEW BOOKING PAGE (Select Resource) -->
    <!-- ============================================================ -->

    <template id="portal_new_booking" name="New Booking">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <h3 class="mb-4">New Booking</h3>

            <div class="alert alert-info" role="alert">
                <i class="fa fa-info-circle"/> Select a resource below to view available time slots and make a booking.
            </div>

            <div class="row">
                <t t-foreach="resources" t-as="resource">
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100">
                            <t t-if="resource.image">
                                <img t-attf-src="/web/image/booking.resource.type/#{resource.id}/image"
                                     class="card-img-top"
                                     style="height: 150px; object-fit: cover;"
                                     t-att-alt="resource.name"/>
                            </t>
                            <div class="card-body">
                                <h5 class="card-title"><t t-esc="resource.name"/></h5>
                                <p class="card-text text-muted small">
                                    <t t-if="resource.location">
                                        <i class="fa fa-map-marker"/> <t t-esc="resource.location"/><br/>
                                    </t>
                                    <i class="fa fa-clock-o"/> <t t-esc="resource.slot_duration"/> hour slots
                                </p>
                            </div>
                            <div class="card-footer bg-transparent">
                                <a t-attf-href="/my/booking/resources/#{resource.id}" class="btn btn-primary btn-sm btn-block">
                                    Select &amp; Book
                                </a>
                            </div>
                        </div>
                    </div>
                </t>
            </div>

            <div class="mt-3">
                <a href="/my/bookings" class="btn btn-secondary">
                    <i class="fa fa-arrow-left"/> Back to My Bookings
                </a>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- BOOKING CONFIRMATION PAGE -->
    <!-- ============================================================ -->

    <template id="portal_booking_confirm" name="Booking Confirmation">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <h3 class="mb-4">Confirm Booking</h3>

            <div class="row">
                <div class="col-lg-8">
                    <form id="confirm-booking-form" action="/my/bookings/create" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="resource_id" t-att-value="resource.id"/>
                        <input type="hidden" name="start_datetime" t-att-value="start_datetime"/>
                        <input type="hidden" name="end_datetime" t-att-value="end_datetime"/>

                        <div class="card">
                            <div class="card-header ws-card-header-accent">
                                <span>
                                    <i class="fa fa-calendar-check-o"/> Booking Summary
                                </span>
                            </div>
                            <div class="card-body">
                                <!-- Subject input -->
                                <div class="mb-3">
                                    <label for="subject" class="form-label fw-bold">Subject (optional)</label>
                                    <input type="text" name="subject" id="subject" class="form-control"
                                           placeholder="e.g. Department Weekly Meeting"/>
                                </div>

                                <!-- Resource Info -->
                                <h6 class="text-muted mb-2">Resource Info</h6>
                                <dl class="row">
                                    <dt class="col-5 col-sm-4">Resource</dt>
                                    <dd class="col-7 col-sm-8"><t t-esc="resource.name"/></dd>

                                    <t t-if="resource.location">
                                        <dt class="col-5 col-sm-4">Location</dt>
                                        <dd class="col-7 col-sm-8"><t t-esc="resource.location"/></dd>
                                    </t>

                                    <t t-if="resource.capacity">
                                        <dt class="col-5 col-sm-4">Capacity</dt>
                                        <dd class="col-7 col-sm-8"><t t-esc="resource.capacity"/> people</dd>
                                    </t>
                                </dl>

                                <hr/>

                                <!-- Time Info -->
                                <h6 class="text-muted mb-2">Time</h6>
                                <dl class="row">
                                    <dt class="col-5 col-sm-4">Start</dt>
                                    <dd class="col-7 col-sm-8">
                                        <t t-esc="start_dt.strftime('%A, %B %d, %Y %H:%M')"/>
                                    </dd>

                                    <dt class="col-5 col-sm-4">End</dt>
                                    <dd class="col-7 col-sm-8">
                                        <t t-esc="end_dt.strftime('%A, %B %d, %Y %H:%M')"/>
                                    </dd>

                                    <dt class="col-5 col-sm-4">Duration</dt>
                                    <dd class="col-7 col-sm-8"><t t-esc="'%.1f' % duration"/> hour(s)</dd>
                                </dl>

                                <hr/>

                                <!-- Organizer (read-only) -->
                                <h6 class="text-muted mb-2">People</h6>
                                <dl class="row">
                                    <dt class="col-5 col-sm-4">Organizer</dt>
                                    <dd class="col-7 col-sm-8"><t t-esc="partner.name"/></dd>
                                </dl>

                                <!-- Discussion Channel Option (only if resource allows) -->
                                <t t-if="resource.enable_discussion">
                                    <hr/>
                                    <div class="form-check mb-3">
                                        <input type="checkbox" name="enable_discussion" id="enable_discussion"
                                               class="form-check-input"/>
                                        <label for="enable_discussion" class="form-check-label">
                                            Enable Discussion Channel
                                        </label>
                                        <div class="form-text">Create a discussion channel for this booking to collaborate with attendees.</div>
                                    </div>
                                </t>

                                <!-- Description textarea -->
                                <hr/>
                                <div class="mb-0">
                                    <label for="description" class="form-label fw-bold">Description (optional)</label>
                                    <textarea name="description" id="description" class="form-control"
                                              rows="3"
                                              placeholder="Add a description or notes..."/>
                                </div>
                            </div>
                            <div class="card-footer">
                                <div class="d-flex flex-column-reverse flex-sm-row justify-content-between gap-2">
                                    <a t-attf-href="/my/booking/resources/#{resource.id}"
                                       class="btn btn-secondary">
                                        <i class="fa fa-arrow-left"/> Back
                                    </a>
                                    <button type="submit" class="btn btn-primary ws-btn-confirm">
                                        <i class="fa fa-check"/> Confirm Booking
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Resource Info Sidebar -->
                <div class="col-lg-4 mt-4 mt-lg-0">
                    <div class="card ws-card-accent">
                        <div class="card-header">
                            <i class="fa fa-info-circle"/> Resource Info
                        </div>
                        <div class="card-body">
                            <t t-if="resource.image">
                                <img t-attf-src="/web/image/booking.resource.type/#{resource.id}/image"
                                     class="img-fluid mb-3"
                                     t-att-alt="resource.name"/>
                            </t>
                            <h6><t t-esc="resource.name"/></h6>
                            <t t-if="resource.description">
                                <div t-raw="resource.description"/>
                            </t>
                        </div>
                        <div class="card-footer">
                            <a t-attf-href="/my/booking/resources/#{resource.id}"
                               class="btn btn-outline-primary btn-sm btn-block">
                                <i class="fa fa-calendar"/> View Available Slots
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- NO RESOURCES AVAILABLE -->
    <!-- ============================================================ -->

    <template id="portal_no_resources" name="No Resources Available">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <h3 class="mb-4">No Resources Available</h3>

            <div class="alert alert-warning" role="alert">
                <h4 class="alert-heading"><i class="fa fa-exclamation-triangle"/> No Resources Available</h4>
                <p>There are currently no resources available for you to book.</p>
                <hr/>
                <p class="mb-0">Please contact the administrator if you believe you should have access to booking resources.</p>
            </div>

            <a href="/my" class="btn btn-secondary">
                <i class="fa fa-arrow-left"/> Back to Portal
            </a>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- INJECT GOOGLE FONTS INTO HEAD -->
    <!-- ============================================================ -->
    <template id="booking_google_fonts" name="Booking Google Fonts" inherit_id="web.frontend_layout">
        <xpath expr="//head/link[1]" position="before">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
            <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700&amp;display=swap" rel="stylesheet"/>
        </xpath>
    </template>
</odoo>
