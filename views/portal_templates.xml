<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Portal Home — Internal Resource entry card
         ============================================================ -->
    <template id="portal_my_home_booking" name="Show Booking Count"
              inherit_id="portal.portal_my_home" priority="25">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_service_category_enable" t-value="True"/>
        </xpath>
        <xpath expr="//div[@id='portal_service_category']" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/odoo_booking_reservation/static/description/images/internal_resource.svg'"/>
                <t t-set="title">Internal Resource</t>
                <t t-set="url" t-value="'/my/internal-resources'"/>
                <t t-set="text">Browse resources and manage your bookings</t>
                <t t-set="config_card" t-value="True"/>
            </t>
        </xpath>
    </template>

    <!-- ============================================================
         Breadcrumbs
         ============================================================ -->
    <template id="portal_breadcrumbs_booking" name="Booking Portal Breadcrumbs"
              inherit_id="portal.portal_breadcrumbs" priority="30">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <!-- Level 1: Internal Resource hub -->
            <li t-if="page_name in ('internal_resources', 'booking_resources', 'booking_resource_detail', 'my_bookings', 'booking_detail', 'booking_new', 'booking_confirm')"
                t-attf-class="breadcrumb-item #{'active' if page_name == 'internal_resources' else ''}">
                <a t-if="page_name != 'internal_resources'" href="/my/internal-resources">
                    Internal Resource
                </a>
                <t t-else="">Internal Resource</t>
            </li>

            <!-- Level 2a: Available Resources -->
            <li t-if="page_name in ('booking_resources', 'booking_resource_detail', 'booking_confirm')"
                t-attf-class="breadcrumb-item #{'active' if page_name == 'booking_resources' else ''}">
                <a t-if="page_name != 'booking_resources'" href="/my/booking/resources">
                    Available Resources
                </a>
                <t t-else="">Available Resources</t>
            </li>

            <!-- Level 3a: Specific Resource -->
            <li t-if="page_name in ('booking_resource_detail', 'booking_confirm') and resource"
                t-attf-class="breadcrumb-item #{'active' if page_name == 'booking_resource_detail' else ''}">
                <a t-if="page_name != 'booking_resource_detail'"
                   t-attf-href="/my/booking/resources/#{resource.id}">
                    <t t-esc="resource.name"/>
                </a>
                <t t-else=""><t t-esc="resource.name"/></t>
            </li>

            <!-- Level 4a: Confirm Booking -->
            <li t-if="page_name == 'booking_confirm'" class="breadcrumb-item active">
                Confirm Booking
            </li>

            <!-- Level 2b: My Bookings -->
            <li t-if="page_name in ('my_bookings', 'booking_detail')"
                t-attf-class="breadcrumb-item #{'active' if page_name == 'my_bookings' else ''}">
                <a t-if="page_name != 'my_bookings'" href="/my/bookings">
                    My Bookings
                </a>
                <t t-else="">My Bookings</t>
            </li>

            <!-- Level 3b: Specific Booking -->
            <li t-if="page_name == 'booking_detail' and reservation" class="breadcrumb-item active">
                Booking #<t t-esc="reservation.id"/>
            </li>

            <!-- Level 2c: New Booking -->
            <li t-if="page_name == 'booking_new'" class="breadcrumb-item active">
                New Booking
            </li>
        </xpath>
    </template>

    <!-- ============================================================
         Internal Resources Hub
         ============================================================ -->
    <template id="portal_internal_resources" name="Internal Resources">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <div class="o_portal_my_home">
                <div class="o_portal_category row g-2 mt-3">
                    <t t-call="portal.portal_docs_entry">
                        <t t-set="icon" t-value="'/odoo_booking_reservation/static/description/images/resource.svg'"/>
                        <t t-set="title">Available Resources</t>
                        <t t-set="url" t-value="'/my/booking/resources'"/>
                        <t t-set="text">Browse and book available resources</t>
                        <t t-set="config_card" t-value="True"/>
                    </t>
                    <t t-call="portal.portal_docs_entry">
                        <t t-set="icon" t-value="'/odoo_booking_reservation/static/description/images/booking.svg'"/>
                        <t t-set="title">My Bookings</t>
                        <t t-set="url" t-value="'/my/bookings'"/>
                        <t t-set="text">View and manage your booking history</t>
                        <t t-set="config_card" t-value="True"/>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================
         Resource List — Native Odoo Table
         ============================================================ -->
    <template id="portal_my_resources" name="Booking Resources">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Available Resources</t>
            </t>

            <t t-if="not resources">
                <div class="alert alert-warning" role="alert">
                    There are no resources available for booking at this time.
                </div>
            </t>

            <t t-if="resources">
                <t t-call="portal.portal_table">
                    <thead>
                        <tr class="active">
                            <th>Resource</th>
                            <th class="d-none d-md-table-cell">Location</th>
                            <th class="d-none d-md-table-cell">Capacity</th>
                            <th class="d-none d-md-table-cell">Duration</th>
                            <th class="text-end"/>
                        </tr>
                    </thead>
                    <t t-foreach="resources" t-as="resource">
                        <tr>
                            <td>
                                <a t-attf-href="/my/booking/resources/#{resource.id}">
                                    <t t-esc="resource.name"/>
                                </a>
                            </td>
                            <td class="d-none d-md-table-cell">
                                <t t-if="resource.location" t-esc="resource.location"/>
                                <t t-else="">—</t>
                            </td>
                            <td class="d-none d-md-table-cell">
                                <t t-if="resource.capacity" t-esc="resource.capacity"/>
                                <t t-else="">—</t>
                            </td>
                            <td class="d-none d-md-table-cell">
                                <t t-esc="resource.slot_duration"/> hours
                            </td>
                            <td class="text-end">
                                <a t-attf-href="/my/booking/resources/#{resource.id}">Book</a>
                            </td>
                        </tr>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================
         Resource Detail — Slot Picker
         ============================================================ -->
    <template id="portal_resource_detail" name="Resource Detail">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <h3 class="page-header mt-3"><t t-esc="resource.name"/></h3>

            <!-- Error alerts -->
            <t t-if="error == 'slot_taken'">
                <div class="alert alert-danger" role="alert">
                    This time slot is already booked. Please choose another available slot.
                </div>
            </t>
            <t t-if="error == 'invalid_datetime'">
                <div class="alert alert-danger" role="alert">
                    Invalid date/time format. Please try again.
                </div>
            </t>
            <t t-if="error == 'past_slot'">
                <div class="alert alert-warning" role="alert">
                    Cannot book a past time slot. Please select a future slot.
                </div>
            </t>
            <t t-if="error == 'too_far_ahead'">
                <div class="alert alert-warning" role="alert">
                    This slot exceeds the booking window.
                </div>
            </t>

            <div class="row mt-3">
                <!-- Resource Info Sidebar -->
                <div class="col-lg-4 mb-4 order-2 order-lg-1">
                    <div class="card">
                        <t t-if="resource.image">
                            <img t-attf-src="/web/image/booking.resource.type/#{resource.id}/image"
                                 class="card-img-top d-none d-lg-block"
                                 t-att-alt="resource.name"/>
                        </t>
                        <div class="card-body">
                            <h5 class="card-title d-none d-lg-block"><t t-esc="resource.name"/></h5>
                            <dl class="row mb-0">
                                <t t-if="resource.location">
                                    <dt class="col-4 col-lg-5">Location</dt>
                                    <dd class="col-8 col-lg-7"><t t-esc="resource.location"/></dd>
                                </t>
                                <t t-if="resource.capacity">
                                    <dt class="col-4 col-lg-5">Capacity</dt>
                                    <dd class="col-8 col-lg-7"><t t-esc="resource.capacity"/></dd>
                                </t>
                                <dt class="col-4 col-lg-5">Duration</dt>
                                <dd class="col-8 col-lg-7"><t t-esc="resource.slot_duration"/> hours</dd>
                            </dl>
                            <t t-if="resource.description">
                                <hr/>
                                <div t-out="resource.description"/>
                            </t>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="/my/booking/resources" class="btn btn-light">
                            <i class="fa fa-arrow-left"/> Back to Resources
                        </a>
                    </div>
                </div>

                <!-- Available Slots -->
                <div class="col-lg-8 order-1 order-lg-2">
                    <div class="card">
                        <div class="card-header">
                            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2">
                                <span><i class="fa fa-calendar"/> Available Slots</span>
                                <div class="d-flex align-items-center">
                                    <t t-if="show_prev">
                                        <a t-attf-href="/my/booking/resources/#{resource.id}?date=#{prev_week}"
                                           class="btn btn-sm btn-light">
                                            <i class="fa fa-chevron-left"/>
                                        </a>
                                    </t>
                                    <t t-else="">
                                        <span class="btn btn-sm btn-light disabled">
                                            <i class="fa fa-chevron-left"/>
                                        </span>
                                    </t>
                                    <span class="mx-2 text-nowrap small fw-bold">
                                        <t t-esc="date_from_str"/> - <t t-esc="date_to_str"/>
                                    </span>
                                    <t t-if="show_next">
                                        <a t-attf-href="/my/booking/resources/#{resource.id}?date=#{next_week}"
                                           class="btn btn-sm btn-light">
                                            <i class="fa fa-chevron-right"/>
                                        </a>
                                    </t>
                                    <t t-else="">
                                        <span class="btn btn-sm btn-light disabled">
                                            <i class="fa fa-chevron-right"/>
                                        </span>
                                    </t>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <t t-if="not slots">
                                <div class="alert alert-info mb-0">
                                    No available slots during this period.
                                </div>
                            </t>

                            <t t-foreach="slots_by_date.items()" t-as="date_slots">
                                <h6 class="mt-3 mb-2 fw-bold">
                                    <t t-esc="date_slots[0]"/>
                                </h6>
                                <div class="row">
                                    <t t-foreach="date_slots[1]" t-as="slot">
                                        <div class="col-6 col-md-4 col-lg-3 mb-2">
                                            <t t-if="slot['is_available']">
                                                <a t-attf-href="/my/bookings/confirm?resource_id=#{resource.id}&amp;start_datetime=#{slot['start'].strftime('%Y-%m-%d %H:%M:%S')}&amp;end_datetime=#{slot['end'].strftime('%Y-%m-%d %H:%M:%S')}"
                                                   class="btn btn-outline-success btn-sm w-100">
                                                    <t t-esc="slot['start_str'].split(' ')[1]"/> - <t t-esc="slot['end_str']"/>
                                                </a>
                                            </t>
                                            <t t-elif="slot['is_mine']">
                                                <a t-attf-href="/my/bookings/#{slot['reservation_id']}"
                                                   class="btn btn-sm btn-light w-100">
                                                    <t t-esc="slot['start_str'].split(' ')[1]"/> - <t t-esc="slot['end_str']"/>
                                                    <br/><small>Your Booking</small>
                                                </a>
                                            </t>
                                            <t t-else="">
                                                <button class="btn btn-sm btn-light w-100" disabled="disabled">
                                                    <t t-esc="slot['start_str'].split(' ')[1]"/> - <t t-esc="slot['end_str']"/>
                                                    <br/><small>Booked</small>
                                                </button>
                                            </t>
                                        </div>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================
         My Bookings List — Native Odoo Table
         ============================================================ -->
    <template id="portal_my_bookings" name="My Bookings">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">My Bookings</t>
            </t>

            <t t-if="not reservations">
                <div class="alert alert-warning" role="alert">
                    You don't have any bookings yet.
                    <a href="/my/booking/resources">Browse available resources</a> to make a booking.
                </div>
            </t>

            <t t-if="reservations">
                <t t-call="portal.portal_table">
                    <thead>
                        <tr class="active">
                            <th>Resource</th>
                            <th class="d-none d-md-table-cell">Date &amp; Time</th>
                            <th class="d-none d-md-table-cell">Duration</th>
                            <th class="text-center">Status</th>
                            <th class="text-end"/>
                        </tr>
                    </thead>
                    <t t-foreach="reservations" t-as="res">
                        <tr t-att-class="'text-muted' if res.state == 'cancelled' else ''">
                            <td>
                                <a t-attf-href="/my/bookings/#{res.id}">
                                    <t t-esc="res.resource_type_id.name"/>
                                </a>
                                <t t-if="res.resource_location">
                                    <div class="small text-muted">
                                        <i class="fa fa-map-marker"/> <t t-esc="res.resource_location"/>
                                    </div>
                                </t>
                            </td>
                            <td class="d-none d-md-table-cell">
                                <t t-esc="res.start_datetime" t-options="{'widget': 'datetime', 'format': 'MMM dd, yyyy HH:mm'}"/>
                            </td>
                            <td class="d-none d-md-table-cell">
                                <t t-esc="'%.1f' % res.duration"/> hours
                            </td>
                            <td class="text-center">
                                <span t-if="res.state == 'confirmed'" class="badge rounded-pill text-bg-success">Confirmed</span>
                                <span t-if="res.state == 'cancelled'" class="badge rounded-pill text-bg-danger">Cancelled</span>
                            </td>
                            <td class="text-end">
                                <a t-attf-href="/my/bookings/#{res.id}">View</a>
                            </td>
                        </tr>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <!-- ============================================================
         Booking Detail — Sidebar + Chatter + Record Pager
         ============================================================ -->
    <template id="portal_booking_detail" name="Booking Detail"
              inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">

            <div class="row">
                <!-- Sidebar -->
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-4 col-xxl-3 d-print-none'"/>

                    <t t-set="entries">
                        <div class="d-flex flex-wrap flex-column gap-4">
                            <!-- Navigation -->
                            <div class="d-flex align-items-center flex-grow-1 p-0" t-ignore="true" role="complementary">
                                <ul class="nav flex-column">
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#card_header">Booking Details</a>
                                    </li>
                                    <li t-if="reservation.channel_id" class="nav-item">
                                        <a class="nav-link p-0" href="#booking_discussion">Discussion</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link p-0" href="#booking_chat">History</a>
                                    </li>
                                </ul>
                            </div>

                            <!-- Booking Info -->
                            <div class="d-flex flex-column gap-2">
                                <div>
                                    <small class="text-muted">Status</small><br/>
                                    <span t-if="reservation.state == 'confirmed'" class="badge rounded-pill text-bg-success">Confirmed</span>
                                    <span t-if="reservation.state == 'cancelled'" class="badge rounded-pill text-bg-danger">Cancelled</span>
                                </div>
                                <div>
                                    <small class="text-muted">Resource</small><br/>
                                    <a t-attf-href="/my/booking/resources/#{reservation.resource_type_id.id}">
                                        <t t-esc="reservation.resource_type_id.name"/>
                                    </a>
                                </div>
                                <div t-if="reservation.resource_location">
                                    <small class="text-muted">Location</small><br/>
                                    <span t-esc="reservation.resource_location"/>
                                </div>
                                <div>
                                    <small class="text-muted">Booker</small><br/>
                                    <span t-esc="reservation.partner_id.name"/>
                                </div>
                                <div t-if="reservation.organizer_id">
                                    <small class="text-muted">Organizer</small><br/>
                                    <span t-esc="reservation.organizer_id.name"/>
                                </div>
                            </div>

                            <!-- Actions -->
                            <div class="d-flex flex-column gap-2">
                                <a t-attf-href="/my/booking/resources/#{reservation.resource_type_id.id}"
                                   class="btn btn-light btn-sm">
                                    <i class="fa fa-calendar"/> Book Again
                                </a>
                                <t t-if="reservation.state == 'confirmed'">
                                    <form t-attf-action="/my/bookings/#{reservation.id}/cancel" method="post">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <button type="submit" class="btn btn-danger btn-sm w-100"
                                                onclick="return confirm('Are you sure you want to cancel this booking?');">
                                            <i class="fa fa-times"/> Cancel Booking
                                        </button>
                                    </form>
                                </t>
                            </div>
                        </div>
                    </t>
                </t>

                <!-- Main Content -->
                <div id="booking_content" class="o_portal_content col-12 col-lg-8 col-xxl-9">

                    <!-- Success/Error Messages -->
                    <t t-if="success == 'created'">
                        <div class="alert alert-success" role="alert">
                            Your booking has been confirmed!
                        </div>
                    </t>
                    <t t-if="success == 'cancelled'">
                        <div class="alert alert-warning" role="alert">
                            Your booking has been cancelled.
                        </div>
                    </t>
                    <t t-if="error == 'cannot_cancel'">
                        <div class="alert alert-danger" role="alert">
                            Unable to cancel this booking.
                        </div>
                    </t>
                    <t t-elif="error">
                        <div class="alert alert-danger" role="alert">
                            <t t-esc="error"/>
                        </div>
                    </t>

                    <div id="card">
                        <div id="card_header" data-anchor="true">
                            <div class="row justify-content-between mb-3">
                                <div class="col-12 col-md-9">
                                    <h3 class="my-0">
                                        <t t-if="reservation.subject" t-esc="reservation.subject"/>
                                        <t t-else="">Booking #<t t-esc="reservation.id"/></t>
                                        <small class="text-muted d-none d-md-inline">
                                            — <t t-esc="reservation.resource_type_id.name"/>
                                        </small>
                                    </h3>
                                </div>
                                <div class="col-auto">
                                    <span t-if="reservation.state == 'confirmed'" class="badge rounded-pill text-bg-success">Confirmed</span>
                                    <span t-if="reservation.state == 'cancelled'" class="badge rounded-pill text-bg-danger">Cancelled</span>
                                </div>
                            </div>
                        </div>

                        <div id="card_body">
                            <!-- Time Details -->
                            <div class="row mb-4">
                                <div class="col-12 col-md-6">
                                    <div><strong>Start:</strong>
                                        <span t-field="reservation.start_datetime" t-options="{'widget': 'datetime'}"/>
                                    </div>
                                    <div><strong>End:</strong>
                                        <span t-field="reservation.end_datetime" t-options="{'widget': 'datetime'}"/>
                                    </div>
                                    <div><strong>Duration:</strong>
                                        <t t-esc="'%.1f' % reservation.duration"/> hours
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div><strong>Resource:</strong>
                                        <t t-esc="reservation.resource_type_id.name"/>
                                    </div>
                                    <div t-if="reservation.resource_location">
                                        <strong>Location:</strong>
                                        <t t-esc="reservation.resource_location"/>
                                    </div>
                                </div>
                            </div>

                            <!-- People -->
                            <div t-if="reservation.attendee_ids" class="mb-4">
                                <h5 class="mb-1">Attendees</h5>
                                <hr class="mt-1 mb-2"/>
                                <div>
                                    <t t-foreach="reservation.attendee_ids" t-as="att">
                                        <span class="badge text-bg-secondary me-1"><t t-esc="att.name"/></span>
                                    </t>
                                </div>
                            </div>

                            <!-- Discussion Channel -->
                            <div t-if="reservation.channel_id" id="booking_discussion" data-anchor="true" class="mb-4">
                                <h5 class="mb-1">Discussion</h5>
                                <hr class="mt-1 mb-2"/>
                                <a t-attf-href="/my/bookings/#{reservation.id}/discuss">
                                    <i class="fa fa-comments"/> <t t-esc="reservation.channel_id.name"/>
                                </a>
                            </div>

                            <!-- Description -->
                            <div t-if="reservation.description" class="mb-4">
                                <h5 class="mb-1">Description</h5>
                                <hr class="mt-1 mb-2"/>
                                <div class="py-1 px-2 bg-100 small" t-out="reservation.description"/>
                            </div>

                            <!-- Notes -->
                            <div t-if="reservation.note" class="mb-4">
                                <h5 class="mb-1">Notes</h5>
                                <hr class="mt-1 mb-2"/>
                                <div class="py-1 px-2 bg-100 small"><t t-esc="reservation.note"/></div>
                            </div>
                        </div>
                    </div>

                    <hr/>
                    <!-- Chatter -->
                    <div id="booking_chat" data-anchor="true">
                        <h3>Communication history</h3>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="reservation"/>
                        </t>
                    </div>
                </div>
            </div>

            <!-- Record Pager (prev/next) -->
            <t t-call="portal.record_pager"/>
        </xpath>
    </template>

    <!-- ============================================================
         New Booking Page (Select Resource)
         ============================================================ -->
    <template id="portal_new_booking" name="New Booking">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <h3 class="page-header mt-3">New Booking</h3>

            <!-- Error alerts -->
            <t t-if="error == 'missing_fields'">
                <div class="alert alert-danger" role="alert">
                    Required fields are missing. Please try again.
                </div>
            </t>
            <t t-if="error == 'invalid_resource'">
                <div class="alert alert-danger" role="alert">
                    The selected resource is invalid.
                </div>
            </t>
            <t t-if="error == 'unauthorized'">
                <div class="alert alert-danger" role="alert">
                    You do not have permission to access this resource.
                </div>
            </t>
            <t t-if="error == 'invalid_datetime'">
                <div class="alert alert-danger" role="alert">
                    Invalid date/time format.
                </div>
            </t>
            <t t-if="error == 'system_error'">
                <div class="alert alert-danger" role="alert">
                    A system error occurred. Please try again later or contact the administrator.
                </div>
            </t>

            <div class="alert alert-info" role="alert">
                Select a resource below to view available time slots and make a booking.
            </div>

            <t t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Resource</th>
                        <th class="d-none d-md-table-cell">Location</th>
                        <th class="d-none d-md-table-cell">Slot Duration</th>
                        <th class="text-end"/>
                    </tr>
                </thead>
                <t t-foreach="resources" t-as="resource">
                    <tr>
                        <td>
                            <a t-attf-href="/my/booking/resources/#{resource.id}">
                                <t t-esc="resource.name"/>
                            </a>
                        </td>
                        <td class="d-none d-md-table-cell">
                            <t t-if="resource.location" t-esc="resource.location"/>
                            <t t-else="">—</t>
                        </td>
                        <td class="d-none d-md-table-cell">
                            <t t-esc="resource.slot_duration"/> hours
                        </td>
                        <td class="text-end">
                            <a t-attf-href="/my/booking/resources/#{resource.id}">
                                Select &amp; Book
                            </a>
                        </td>
                    </tr>
                </t>
            </t>

            <div class="mt-3">
                <a href="/my/internal-resources" class="btn btn-light">
                    <i class="fa fa-arrow-left"/> Back
                </a>
            </div>
        </t>
    </template>

    <!-- ============================================================
         Booking Confirmation Page
         ============================================================ -->
    <template id="portal_booking_confirm" name="Confirm Booking">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <h3 class="page-header mt-3">Confirm Booking</h3>

            <div class="row mt-3">
                <div class="col-lg-8">
                    <form id="confirm-booking-form" action="/my/bookings/create" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="resource_id" t-att-value="resource.id"/>
                        <input type="hidden" name="start_datetime" t-att-value="start_datetime"/>
                        <input type="hidden" name="end_datetime" t-att-value="end_datetime"/>

                        <div class="card">
                            <div class="card-header">
                                <i class="fa fa-calendar-check-o"/> Booking Summary
                            </div>
                            <div class="card-body">
                                <!-- Subject input -->
                                <div class="mb-3">
                                    <label for="subject" class="form-label fw-bold">Booking Subject (Optional)</label>
                                    <input type="text" name="subject" id="subject" class="form-control"
                                           placeholder="e.g. Weekly Team Meeting"/>
                                </div>

                                <!-- Resource Info -->
                                <h6 class="text-muted mb-2">Resource Information</h6>
                                <div class="row mb-3">
                                    <div class="col-12 col-md-6">
                                        <div><strong>Resource:</strong> <t t-esc="resource.name"/></div>
                                        <t t-if="resource.location">
                                            <div><strong>Location:</strong> <t t-esc="resource.location"/></div>
                                        </t>
                                        <t t-if="resource.capacity">
                                            <div><strong>Capacity:</strong> <t t-esc="resource.capacity"/></div>
                                        </t>
                                    </div>
                                </div>

                                <hr/>

                                <!-- Time Info -->
                                <h6 class="text-muted mb-2">Time</h6>
                                <div class="row mb-3">
                                    <div class="col-12 col-md-6">
                                        <div><strong>Start:</strong> <t t-esc="start_dt.strftime('%A, %B %d, %Y %H:%M')"/></div>
                                        <div><strong>End:</strong> <t t-esc="end_dt.strftime('%A, %B %d, %Y %H:%M')"/></div>
                                        <div><strong>Duration:</strong> <t t-esc="'%.1f' % duration"/> hours</div>
                                    </div>
                                </div>

                                <hr/>

                                <!-- Organizer -->
                                <h6 class="text-muted mb-2">People</h6>
                                <div class="mb-3">
                                    <strong>Organizer:</strong> <t t-esc="partner.name"/>
                                </div>

                                <!-- Attendees -->
                                <div class="mb-3">
                                    <label for="attendee_search" class="form-label fw-bold">Attendees (Optional)</label>
                                    <div class="position-relative" id="attendee-widget">
                                        <div id="attendee-tags" class="d-flex flex-wrap gap-1 mb-2"/>
                                        <input type="text" id="attendee_search" class="form-control"
                                               placeholder="Search colleagues by name..."
                                               autocomplete="off"/>
                                        <div id="attendee-dropdown" class="dropdown-menu w-100" style="max-height:200px;overflow-y:auto;"/>
                                        <input type="hidden" name="attendee_ids" id="attendee_ids" value=""/>
                                    </div>
                                    <div class="form-text">Add colleagues from your company as meeting attendees.</div>
                                </div>

                                <!-- Discussion Channel Option -->
                                <t t-if="resource.enable_discussion">
                                    <hr/>
                                    <div class="form-check mb-3">
                                        <input type="checkbox" name="enable_discussion" id="enable_discussion"
                                               class="form-check-input"/>
                                        <label for="enable_discussion" class="form-check-label">
                                            Enable Discussion Channel
                                        </label>
                                        <div class="form-text">Create a discussion channel for this booking to collaborate with attendees.</div>
                                    </div>
                                </t>

                                <!-- Description textarea -->
                                <hr/>
                                <div class="mb-0">
                                    <label for="description" class="form-label fw-bold">Description (Optional)</label>
                                    <textarea name="description" id="description" class="form-control"
                                              rows="3"
                                              placeholder="Add a description or notes..."/>
                                </div>
                            </div>
                            <div class="card-footer">
                                <div class="d-flex flex-column-reverse flex-sm-row justify-content-between gap-2">
                                    <a t-attf-href="/my/booking/resources/#{resource.id}"
                                       class="btn btn-light">
                                        <i class="fa fa-arrow-left"/> Back
                                    </a>
                                    <button type="submit" class="btn btn-success">
                                        <i class="fa fa-check"/> Confirm Booking
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Resource Info Sidebar -->
                <div class="col-lg-4 mt-4 mt-lg-0">
                    <div class="card">
                        <div class="card-header">
                            <i class="fa fa-info-circle"/> Resource Information
                        </div>
                        <div class="card-body">
                            <t t-if="resource.image">
                                <img t-attf-src="/web/image/booking.resource.type/#{resource.id}/image"
                                     class="img-fluid mb-3"
                                     t-att-alt="resource.name"/>
                            </t>
                            <h6><t t-esc="resource.name"/></h6>
                            <t t-if="resource.description">
                                <div t-out="resource.description"/>
                            </t>
                        </div>
                        <div class="card-footer">
                            <a t-attf-href="/my/booking/resources/#{resource.id}"
                               class="btn btn-light btn-sm w-100">
                                <i class="fa fa-calendar"/> View Available Slots
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================
         No Resources Available
         ============================================================ -->
    <template id="portal_no_resources" name="No Resources Available">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>

            <h3 class="page-header mt-3">No Resources Available</h3>

            <div class="alert alert-warning" role="alert">
                There are currently no resources available for you to book.
                If you believe you should have access to booking resources, please contact the administrator.
            </div>

            <a href="/my" class="btn btn-light">
                <i class="fa fa-arrow-left"/> Back to Portal
            </a>
        </t>
    </template>

    <!-- ============================================================
         Discussions Page — Auto-open channel in modal
         (Preserved from booking module — IDOR protection overlay)
         ============================================================ -->
    <template id="portal_discussions_auto_open"
              inherit_id="cs_portal_discuss.portal_discuss_channels"
              name="Auto-open Discussion Channel Modal">
        <xpath expr="//t[@t-call='portal.portal_layout']" position="inside">
            <!-- Modal for discuss channel iframe -->
            <div class="modal fade" id="discussChannelModal" tabindex="-1"
                 aria-labelledby="discussChannelModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-xl modal-dialog-centered" style="max-width: 95vw; height: 90vh;">
                    <div class="modal-content" style="height: 85vh;">
                        <div class="modal-header py-2">
                            <h5 class="modal-title" id="discussChannelModalLabel">Discussion Channel</h5>
                            <button type="button" class="btn-close" id="discussChannelModalClose" aria-label="Close"/>
                        </div>
                        <div class="modal-body p-0" style="height: calc(85vh - 56px); overflow: hidden;">
                            <iframe id="discussChannelFrame"
                                    style="width: 100%; height: 100%; border: none;"/>
                        </div>
                    </div>
                </div>
            </div>

            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    var params = new URLSearchParams(window.location.search);
                    var channelId = params.get('open_channel');
                    if (!channelId) return;

                    var modalEl = document.getElementById('discussChannelModal');
                    var iframe = document.getElementById('discussChannelFrame');
                    var closeBtn = document.getElementById('discussChannelModalClose');
                    if (!modalEl || !iframe) return;

                    iframe.src = '/discuss/channel/' + parseInt(channelId, 10) + '?discussions=1';

                    modalEl.classList.add('show');
                    modalEl.style.display = 'block';
                    modalEl.removeAttribute('aria-hidden');
                    document.body.classList.add('modal-open');

                    var backdrop = document.createElement('div');
                    backdrop.className = 'modal-backdrop fade show';
                    backdrop.id = 'discussModalBackdrop';
                    document.body.appendChild(backdrop);

                    function closeModal() {
                        modalEl.classList.remove('show');
                        modalEl.style.display = 'none';
                        modalEl.setAttribute('aria-hidden', 'true');
                        document.body.classList.remove('modal-open');
                        var bd = document.getElementById('discussModalBackdrop');
                        if (bd) bd.remove();
                        iframe.src = 'about:blank';
                    }

                    if (closeBtn) closeBtn.addEventListener('click', closeModal);

                    modalEl.addEventListener('click', function(e) {
                        if (e.target === modalEl) closeModal();
                    });

                    document.addEventListener('keydown', function(e) {
                        if (e.key === 'Escape' &amp;&amp; modalEl.classList.contains('show')) closeModal();
                    });

                    iframe.addEventListener('load', function() {
                        try {
                            iframe.contentDocument.addEventListener('keydown', function(e) {
                                if (e.key === 'Escape') closeModal();
                            });
                        } catch(ignored) {}
                    });

                    window.history.replaceState({}, document.title, window.location.pathname);
                });
            </script>
        </xpath>
    </template>

</odoo>
