<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_booking_resource_category_tree" model="ir.ui.view">
        <field name="name">booking.resource.category.tree</field>
        <field name="model">booking.resource.category</field>
        <field name="arch" type="xml">
            <list string="Resource Categories">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="resource_count" string="Resources"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_booking_resource_category_form" model="ir.ui.view">
        <field name="name">booking.resource.category.form</field>
        <field name="model">booking.resource.category</field>
        <field name="arch" type="xml">
            <form string="Resource Category">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Category Name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Resources" name="resources">
                            <field name="resource_ids" nolabel="1">
                                <list string="Resources">
                                    <field name="name"/>
                                    <field name="location"/>
                                    <field name="capacity"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_booking_resource_category_search" model="ir.ui.view">
        <field name="name">booking.resource.category.search</field>
        <field name="model">booking.resource.category</field>
        <field name="arch" type="xml">
            <search string="Search Categories">
                <field name="name"/>
                <separator/>
                <filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="filter_archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_booking_resource_category" model="ir.actions.act_window">
        <field name="name">Resource Categories</field>
        <field name="res_model">booking.resource.category</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_booking_resource_category_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first resource category
            </p>
            <p>
                Categories allow you to define custom properties that can be shared across resources.
            </p>
        </field>
    </record>
</odoo>
