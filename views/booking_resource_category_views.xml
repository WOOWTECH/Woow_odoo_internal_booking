<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_booking_resource_category_tree" model="ir.ui.view">
        <field name="name">booking.resource.category.tree</field>
        <field name="model">booking.resource.category</field>
        <field name="arch" type="xml">
            <list string="資源分類">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="resource_count" string="資源數"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_booking_resource_category_form" model="ir.ui.view">
        <field name="name">booking.resource.category.form</field>
        <field name="model">booking.resource.category</field>
        <field name="arch" type="xml">
            <form string="資源分類">
                <sheet>
                    <widget name="web_ribbon" title="已封存" bg_color="text-bg-danger" invisible="active"/>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="分類名稱"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="屬性定義" name="properties">
                            <field name="resource_properties_definition"/>
                            <div class="alert alert-info" role="alert">
                                <strong>提示：</strong>在此定義自訂屬性，這些屬性將適用於此分類下的所有資源。
                                點擊「+」按鈕新增屬性。可用類型：文字、數字、日期、核取方塊、選擇清單、標籤、多對一。
                            </div>
                        </page>

                        <page string="資源" name="resources">
                            <field name="resource_ids" nolabel="1">
                                <list string="資源">
                                    <field name="name"/>
                                    <field name="location"/>
                                    <field name="capacity"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_booking_resource_category" model="ir.actions.act_window">
        <field name="name">資源分類</field>
        <field name="res_model">booking.resource.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                建立您的第一個資源分類
            </p>
            <p>
                分類可讓您定義適用於該分類下所有資源的自訂屬性。
            </p>
        </field>
    </record>
</odoo>
