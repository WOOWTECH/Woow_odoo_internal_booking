#. module: odoo_booking_reservation
#: model:mail.template,body_html:odoo_booking_reservation.mail_template_booking_cancelled
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 14px;\">\n"
"    <p style=\"margin: 0px 0px 16px 0px;\">\n"
"        Hello <t t-out=\"object.partner_id.name or ''\">Contact</t>,\n"
"    </p>\n"
"    <p style=\"margin: 0px 0px 16px 0px;\">\n"
"        Your booking has been cancelled. Here are the details:\n"
"    </p>\n"
"\n"
"    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 16px;\">\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; background-color: #f8f9fa; font-weight: bold; width: 140px; border: 1px solid #dee2e6;\">Resource</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\"><t t-out=\"object.resource_type_id.name or ''\">Resource</t></td>\n"
"        </tr>\n"
"        <t t-if=\"object.subject\">\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; background-color: #f8f9fa; font-weight: bold; border: 1px solid #dee2e6;\">Subject</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\"><t t-out=\"object.subject\">Subject</t></td>\n"
"        </tr>\n"
"        </t>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; background-color: #f8f9fa; font-weight: bold; border: 1px solid #dee2e6;\">Start Time</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\"><t t-out=\"format_datetime(object.start_datetime)\">Start Time</t></td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; background-color: #f8f9fa; font-weight: bold; border: 1px solid #dee2e6;\">End Time</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\"><t t-out=\"format_datetime(object.end_datetime)\">End Time</t></td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; background-color: #f8f9fa; font-weight: bold; border: 1px solid #dee2e6;\">Status</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6; color: #dc3545; font-weight: bold;\">Cancelled</td>\n"
"        </tr>\n"
"    </table>\n"
"\n"
"    <p style=\"margin: 0px 0px 16px 0px;\">\n"
"        <a t-attf-href=\"{{ object.get_base_url() }}/my/booking/resources/{{ object.resource_type_id.id }}\" style=\"display: inline-block; padding: 8px 16px; background-color: #00A09D; color: #ffffff; text-decoration: none; border-radius: 4px;\">\n"
"            Book Again\n"
"        </a>\n"
"    </p>\n"
"\n"
"    <p style=\"margin: 0px; color: #888888; font-size: 12px;\">\n"
"        This is an automated notification from the booking system.\n"
"    </p>\n"
"</div>\n"
"        "
msgstr ""

#. module: odoo_booking_reservation
#: model:mail.template,body_html:odoo_booking_reservation.mail_template_booking_confirmed
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 14px;\">\n"
"    <p style=\"margin: 0px 0px 16px 0px;\">\n"
"        Hello <t t-out=\"object.partner_id.name or ''\">Contact</t>,\n"
"    </p>\n"
"    <p style=\"margin: 0px 0px 16px 0px;\">\n"
"        Your booking has been confirmed. Here are the details:\n"
"    </p>\n"
"\n"
"    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 16px;\">\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; background-color: #f8f9fa; font-weight: bold; width: 140px; border: 1px solid #dee2e6;\">Resource</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\"><t t-out=\"object.resource_type_id.name or ''\">Resource</t></td>\n"
"        </tr>\n"
"        <t t-if=\"object.subject\">\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; background-color: #f8f9fa; font-weight: bold; border: 1px solid #dee2e6;\">Subject</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\"><t t-out=\"object.subject\">Subject</t></td>\n"
"        </tr>\n"
"        </t>\n"
"        <t t-if=\"object.resource_location\">\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; background-color: #f8f9fa; font-weight: bold; border: 1px solid #dee2e6;\">Location</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\"><t t-out=\"object.resource_location\">Location</t></td>\n"
"        </tr>\n"
"        </t>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; background-color: #f8f9fa; font-weight: bold; border: 1px solid #dee2e6;\">Start Time</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\"><t t-out=\"format_datetime(object.start_datetime)\">Start Time</t></td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; background-color: #f8f9fa; font-weight: bold; border: 1px solid #dee2e6;\">End Time</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\"><t t-out=\"format_datetime(object.end_datetime)\">End Time</t></td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px 12px; background-color: #f8f9fa; font-weight: bold; border: 1px solid #dee2e6;\">Organizer</td>\n"
"            <td style=\"padding: 8px 12px; border: 1px solid #dee2e6;\"><t t-out=\"object.organizer_id.name or object.partner_id.name or ''\">Organizer</t></td>\n"
"        </tr>\n"
"    </table>\n"
"\n"
"    <t t-if=\"object.channel_id\">\n"
"    <p style=\"margin: 0px 0px 16px 0px;\">\n"
"        A discussion channel has been created for this booking. You can collaborate with other attendees:\n"
"    </p>\n"
"    <p style=\"margin: 0px 0px 16px 0px;\">\n"
"        <a t-attf-href=\"{{ object.get_base_url() }}/my/bookings/{{ object.id }}/discuss\" style=\"display: inline-block; padding: 8px 16px; background-color: #714B67; color: #ffffff; text-decoration: none; border-radius: 4px;\">\n"
"            <span style=\"margin-right: 4px;\">💬</span> Open Discussion Channel\n"
"        </a>\n"
"    </p>\n"
"    </t>\n"
"\n"
"    <p style=\"margin: 0px 0px 16px 0px;\">\n"
"        <a t-attf-href=\"{{ object.get_base_url() }}/my/bookings/{{ object.id }}\" style=\"display: inline-block; padding: 8px 16px; background-color: #00A09D; color: #ffffff; text-decoration: none; border-radius: 4px;\">\n"
"            View Booking Details\n"
"        </a>\n"
"    </p>\n"
"\n"
"    <p style=\"margin: 0px; color: #888888; font-size: 12px;\">\n"
"        This is an automated notification from the booking system.\n"
"    </p>\n"
"</div>\n"
"        "
msgstr ""

