<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Extend the calendar popover body to add a Discussion Channel link -->
    <t t-name="odoo_booking_reservation.BookingCalendarPopover.body"
       t-inherit="web.CalendarCommonPopover.body"
       t-inherit-mode="extension">
        <xpath expr="//ul[hasclass('o_cw_popover_fields_secondary')]" position="inside">
            <li t-if="props.record.rawRecord.channel_id" class="o_cw_popover_fields_secondary_item d-flex align-items-baseline">
                <i class="fa fa-comments fa-fw me-2 text-muted" title="討論"/>
                <a t-att-href="'/odoo/discuss?active_id=discuss.channel_' + (Array.isArray(props.record.rawRecord.channel_id) ? props.record.rawRecord.channel_id[0] : props.record.rawRecord.channel_id)"
                   class="text-truncate text-decoration-underline">
                    開啟討論通道
                </a>
            </li>
        </xpath>
    </t>
</templates>
